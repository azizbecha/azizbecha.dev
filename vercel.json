{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"rewrites": [
		{ "source": "/api/posts", "destination": "/api/posts.json" },
		{ "source": "/api/posts/:slug", "destination": "/api/posts/:slug.json" }
	],
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "Content-Security-Policy",
					"value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://i.ytimg.com https://github.com https://avatars.githubusercontent.com; frame-src https://www.youtube-nocookie.com https://www.youtube.com; connect-src 'self'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
				},
				{ "key": "X-Frame-Options", "value": "SAMEORIGIN" },
				{ "key": "X-Content-Type-Options", "value": "nosniff" },
				{ "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
				{ "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
			]
		},
		{
			"source": "/_astro/(.*)",
			"headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
		},
		{
			"source": "/pagefind/(.*)",
			"headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
		},
		{
			"source": "/(favicon\\.ico|favicon\\.svg|robots\\.txt)",
			"headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
		},
		{
			"source": "/(.*)\\.html",
			"headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
		}
	]
}
