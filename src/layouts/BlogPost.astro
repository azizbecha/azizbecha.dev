---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Byline from '../components/Byline.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TagChip from '../components/TagChip.astro';

type AdjacentPost = { id: string; title: string };

type Props = Omit<CollectionEntry<'blog'>['data'], 'authors'> & {
	minutes?: number;
	authors?: CollectionEntry<'authors'>[];
	prevPost?: AdjacentPost;
	nextPost?: AdjacentPost;
};

const { title, description, pubDate, updatedDate, heroImage, minutes, authors, tags, prevPost, nextPost } =
	Astro.props;

const jsonLd = JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	...(heroImage && { image: new URL(heroImage.src, Astro.site).href }),
	...(tags && tags.length > 0 && { keywords: tags.join(', ') }),
	author: (authors ?? []).map((author) => ({
		'@type': 'Person',
		name: author.data.name,
		...(author.data.url && { url: author.data.url }),
	})),
	mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href,
});
---

<html lang="en" class="dark">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<script type="application/ld+json" set:html={jsonLd} />
	</head>

	<body>
		<Header />
		<main>
			<article class="w-full max-w-180 mx-auto">
				<header class="mb-10">
					{
						tags && tags.length > 0 && (
							<div class="flex flex-wrap gap-1.5 mb-5 leading-normal">
								{tags.map((tag) => (
									<TagChip tag={tag} link />
								))}
							</div>
						)
					}
					<h1 class="text-4xl! md:text-5xl! leading-tight! mb-5">{title}</h1>
					<div class="flex flex-wrap items-center gap-x-2 text-sm text-muted-foreground leading-normal">
						{authors && authors.length > 0 && (
							<>
								<Byline authors={authors} />
								<span>&middot;</span>
							</>
						)}
						<FormattedDate date={pubDate} />
						{minutes && (
							<>
								<span>&middot;</span>
								<span>{minutes} min read</span>
							</>
						)}
						<span class="ml-auto">
							<ShareButtons title={title} />
						</span>
					</div>
					{
						updatedDate && (
							<p class="m-0! mt-2 text-xs italic text-muted-foreground">
								Last updated on <FormattedDate date={updatedDate} />
							</p>
						)
					}
				</header>

				{
					heroImage && (
						<Image
							class="w-full rounded-xl shadow-(--box-shadow) mb-10!"
							width={1020}
							height={510}
							src={heroImage}
							alt=""
						/>
					)
				}

				<div class="prose" data-pagefind-body>
					<slot />
				</div>

				{
					authors && authors.length > 0 && (
						<footer class="mt-12 border-t border-border pt-8">
							{authors.map((author) => (
								<div class="flex items-start gap-4 not-first:mt-6">
									{author.data.avatar ? (
										<img
											class="size-12 rounded-full! m-0! object-cover shrink-0"
											src={author.data.avatar}
											alt=""
											width="96"
											height="96"
											loading="lazy"
										/>
									) : (
										<span class="size-12 rounded-full bg-muted text-muted-foreground inline-flex items-center justify-center font-semibold uppercase shrink-0">
											{author.data.name
												.split(' ')
												.map((part) => part[0])
												.slice(0, 2)
												.join('')}
										</span>
									)}
									<div class="leading-normal">
										<p class="m-0! font-semibold text-foreground text-base">
											{author.data.url ? (
												<a class="text-inherit! no-underline hover:underline" href={author.data.url}>
													{author.data.name}
												</a>
											) : (
												author.data.name
											)}
										</p>
										{author.data.bio && <p class="m-0! mt-0.5 text-sm text-muted-foreground">{author.data.bio}</p>}
									</div>
								</div>
							))}
						</footer>
					)
				}

				{
					(prevPost || nextPost) && (
						<nav class="mt-10 grid gap-4 sm:grid-cols-2 leading-normal" aria-label="Adjacent posts">
							{prevPost ? (
								<a
									class="group block rounded-lg border border-border p-4 no-underline transition-colors hover:border-(--blog-accent)/60"
									href={`/blog/${prevPost.id}/`}
								>
									<span class="block text-xs text-muted-foreground mb-1">&larr; Older</span>
									<span class="block text-sm font-semibold text-foreground transition-colors group-hover:text-(--blog-accent)">
										{prevPost.title}
									</span>
								</a>
							) : (
								<span />
							)}
							{nextPost && (
								<a
									class="group block rounded-lg border border-border p-4 no-underline text-right transition-colors hover:border-(--blog-accent)/60"
									href={`/blog/${nextPost.id}/`}
								>
									<span class="block text-xs text-muted-foreground mb-1">Newer &rarr;</span>
									<span class="block text-sm font-semibold text-foreground transition-colors group-hover:text-(--blog-accent)">
										{nextPost.title}
									</span>
								</a>
							)}
						</nav>
					)
				}
			</article>
		</main>
		<Footer />
	</body>
</html>

<script is:inline define:vars={{ postTitle: title, postTags: tags ?? [], postMinutes: minutes ?? null }}>
	function capturePostViewed() {
		window.posthog?.capture('blog_post_viewed', {
			post_title: postTitle,
			post_tags: postTags,
			reading_time_minutes: postMinutes
		});
	}
	document.addEventListener('DOMContentLoaded', capturePostViewed);
	document.addEventListener('astro:page-load', capturePostViewed);
</script>
