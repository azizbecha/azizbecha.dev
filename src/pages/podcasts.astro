---
import { Icon } from 'astro-icon/components';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import PODCASTS from '../data/podcasts.json';

const videoId = (url: string) => new URL(url).searchParams.get('v');
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={`Podcasts · ${SITE_TITLE}`} description="Podcasts I keep coming back to." />
	</head>
	<body>
		<Header />
		<main>
			<section class="mt-8 mb-10 max-sm:mt-4">
				<h1 class="text-4xl! mb-2 max-sm:text-3xl!">Podcasts</h1>
				<p class="text-muted-foreground mb-0!">Episodes I keep coming back to.</p>
			</section>

			<ul class="grid gap-6 sm:grid-cols-2 list-none m-0 p-0">
				{
					PODCASTS.map((podcast) => {
						const id = videoId(podcast.url);
						return (
							<li class="m-0 flex flex-col rounded-lg border border-border overflow-hidden transition-colors hover:border-(--blog-accent)/60">
								{id && (
									<button
										type="button"
										class="yt-embed group relative aspect-video w-full cursor-pointer p-0 border-0 bg-transparent"
										data-video-id={id}
										aria-label={`Play: ${podcast.name}`}
									>
										<img
											src={`https://i.ytimg.com/vi/${id}/hqdefault.jpg`}
											alt=""
											width="480"
											height="360"
											class="absolute inset-0 w-full! h-full! object-cover rounded-none! m-0!"
											loading="lazy"
										/>
										<span class="absolute inset-0 flex items-center justify-center bg-black/20 transition-colors group-hover:bg-black/40">
											<span class="flex items-center justify-center size-14 rounded-full bg-black/70 text-white transition-transform group-hover:scale-110">
												<Icon name="lucide:play" class="size-6 ml-0.5" aria-hidden="true" />
											</span>
										</span>
									</button>
								)}
								<div class="flex flex-col flex-1 p-4">
									<a
										class="group/link flex items-start gap-2 font-semibold text-foreground! no-underline transition-colors hover:text-(--blog-accent)!"
										href={podcast.url}
										target="_blank"
										rel="noopener noreferrer"
									>
										{podcast.name}
										<Icon
											name="lucide:arrow-up-right"
											class="size-3.5 shrink-0 mt-1 ml-auto opacity-0 transition-opacity group-hover/link:opacity-100"
											aria-hidden="true"
										/>
									</a>
									<span class="mt-0.5 text-xs text-muted-foreground">{podcast.host}</span>
									<span class="mt-2 text-sm text-muted-foreground">{podcast.note}</span>
								</div>
							</li>
						);
					})
				}
			</ul>
		</main>
		<Footer />

		<script>
			// Facade: thumbnail only until clicked, then swap in the real iframe. Delegated — view-transition safe.
			document.addEventListener('click', (event) => {
				const facade = (event.target as Element).closest('.yt-embed') as HTMLElement | null;
				if (!facade || !facade.dataset.videoId) return;
				const wrapper = document.createElement('div');
				wrapper.className = 'relative aspect-video w-full';
				wrapper.innerHTML = `<iframe
					src="https://www.youtube-nocookie.com/embed/${facade.dataset.videoId}?autoplay=1"
					title="YouTube video player"
					class="absolute inset-0 size-full border-0"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
					allowfullscreen></iframe>`;
				facade.replaceWith(wrapper);
			});
		</script>
	</body>
</html>
