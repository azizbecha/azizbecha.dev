---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import TagChip from '../../components/TagChip.astro';
import { SITE_TITLE } from '../../consts';
import { getAllTags, getPosts } from '../../lib/posts';

const posts = await getPosts();
const tags = await getAllTags();
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={`Blog · ${SITE_TITLE}`} description="Posts about code, projects, and things I'm learning." />
	</head>
	<body>
		<Header />
		<main>
			<section class="mt-8 mb-10 max-sm:mt-4">
				<h1 class="text-4xl! mb-2 max-sm:text-3xl!">Blog</h1>
				<p class="text-muted-foreground mb-0!">
					{posts.length} post{posts.length === 1 ? '' : 's'} so far. Mostly code, occasionally not.
				</p>
			</section>

			{
				tags.size > 0 && (
					<div class="flex flex-wrap gap-1.5 mb-8">
						<TagChip tag="all" link active />
						{[...tags.entries()].map(([tag, count]) => (
							<TagChip tag={tag} count={count} link />
						))}
					</div>
				)
			}

			<ul class="grid gap-6 sm:grid-cols-2 list-none m-0 p-0">
				{
					posts.map((post) => (
						<li class="m-0">
							<PostCard post={post} />
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
