---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import PostCard from '../../../components/PostCard.astro';
import TagChip from '../../../components/TagChip.astro';
import { SITE_TITLE } from '../../../consts';
import { getAllTags, getPostsByTag } from '../../../lib/posts';

export async function getStaticPaths() {
	const tags = await getAllTags();
	return [...tags.keys()].map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const posts = await getPostsByTag(tag);
const tags = await getAllTags();
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={`${tag} · ${SITE_TITLE}`} description={`Posts tagged "${tag}".`} />
	</head>
	<body>
		<Header />
		<main>
			<section class="mt-8 mb-10 max-sm:mt-4">
				<h1 class="text-4xl! mb-2 max-sm:text-3xl!">{tag}</h1>
				<p class="text-muted-foreground mb-0!">
					{posts.length} post{posts.length === 1 ? '' : 's'} tagged <span class="text-foreground">{tag}</span>.
				</p>
			</section>

			<div class="flex flex-wrap gap-1.5 mb-8">
				<TagChip tag="all" link />
				{[...tags.entries()].map(([t, count]) => <TagChip tag={t} count={count} link active={t === tag} />)}
			</div>

			<ul class="grid gap-6 sm:grid-cols-2 list-none m-0 p-0">
				{
					posts.map((post, index) => (
						<li class="m-0">
							<PostCard post={post} eager={index < 2} />
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
