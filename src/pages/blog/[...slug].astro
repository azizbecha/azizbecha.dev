---
import { type CollectionEntry, getEntries, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getPosts, readingTime } from '../../lib/posts';

export async function getStaticPaths() {
	const posts = await getPosts();
	return posts.map((post, index) => ({
		params: { slug: post.id },
		// Posts are newest-first: previous = older, next = newer.
		props: { post, prevPost: posts[index + 1] ?? null, nextPost: posts[index - 1] ?? null },
	}));
}
type Props = {
	post: CollectionEntry<'blog'>;
	prevPost: CollectionEntry<'blog'> | null;
	nextPost: CollectionEntry<'blog'> | null;
};

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
const authors = await getEntries(post.data.authors);
---

<BlogPost
	{...post.data}
	minutes={readingTime(post.body)}
	authors={authors}
	prevPost={prevPost ? { id: prevPost.id, title: prevPost.data.title } : undefined}
	nextPost={nextPost ? { id: nextPost.id, title: nextPost.data.title } : undefined}
>
	<Content />
</BlogPost>
