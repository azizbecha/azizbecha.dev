---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPosts } from '../lib/posts';

const posts = await getPosts(4);
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Hey, I'm Aziz 👋</h1>
				<p>
					I'm a software developer who likes building things for the web. This is my corner of the
					internet — I write about code, projects I'm working on, and whatever I happen to be
					learning.
				</p>
			</section>

			<section class="recent">
				<div class="recent-head">
					<h2>Recent writing</h2>
					<a class="all-posts" href="/blog">All posts &rarr;</a>
				</div>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a class="post" href={`/blog/${post.id}/`}>
									<div class="post-row">
										<span class="post-title">{post.data.title}</span>
										<span class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
									<p class="post-desc">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>

	<style>
		.hero {
			margin: 2rem 0 3.5rem;
		}

		.hero h1 {
			font-size: 2.4em;
			margin-bottom: 0.75rem;
		}

		.hero p {
			color: rgb(var(--gray));
			margin: 0;
			max-width: 38rem;
		}

		.recent-head {
			display: flex;
			align-items: baseline;
			justify-content: space-between;
			gap: 1rem;
			margin-bottom: 1rem;
		}

		.recent-head h2 {
			font-size: 1.4em;
			margin: 0;
		}

		.all-posts {
			font-size: 0.85em;
			text-decoration: none;
			white-space: nowrap;
		}

		.recent ul {
			list-style: none;
			margin: 0;
			padding: 0;
			display: flex;
			flex-direction: column;
		}

		.recent li + li {
			border-top: 1px solid var(--border);
		}

		.post {
			display: block;
			padding: 1rem 0;
			text-decoration: none;
			color: inherit;
		}

		.post-row {
			display: flex;
			align-items: baseline;
			justify-content: space-between;
			gap: 1rem;
		}

		.post-title {
			color: rgb(var(--black));
			font-weight: 600;
			transition: color 0.15s ease;
		}

		.post:hover .post-title {
			color: var(--blog-accent);
		}

		.post-date {
			color: rgb(var(--gray));
			font-size: 0.8em;
			white-space: nowrap;
		}

		.post-desc {
			color: rgb(var(--gray));
			font-size: 0.85em;
			margin: 0.25rem 0 0;
		}

		@media (max-width: 520px) {
			.hero {
				margin-top: 1rem;
			}

			.hero h1 {
				font-size: 1.8em;
			}

			.post-row {
				flex-direction: column;
				gap: 0.15rem;
			}
		}
	</style>
</html>
