---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPosts } from '../lib/posts';

const posts = await getPosts(6);
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="mt-8 mb-14 max-sm:mt-4">
				<h1 class="text-4xl! mb-3 max-sm:text-3xl!">Hey, I'm Aziz 👋</h1>
				<p class="text-muted-foreground mb-0! max-w-xl">
					I'm a software developer who likes building things for the web. This is my corner of the
					internet — I write about code, projects I'm working on, and whatever I happen to be
					learning.
				</p>
			</section>

			<section>
				<div class="flex items-baseline justify-between gap-4 mb-4">
					<h2 class="text-2xl! m-0!">Recent writing</h2>
					<a class="text-sm no-underline whitespace-nowrap" href="/blog">All posts &rarr;</a>
				</div>
				<ul class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 list-none m-0 p-0">
					{
						posts.map((post) => (
							<li class="m-0">
								<PostCard post={post} />
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
