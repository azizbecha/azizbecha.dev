---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getPosts } from '../lib/posts';

const posts = await getPosts(4);
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="mt-8 mb-14 max-sm:mt-4">
				<h1 class="text-4xl! mb-3 max-sm:text-3xl!">Hey, I'm Aziz 👋</h1>
				<p class="text-muted-foreground mb-0! max-w-xl">
					I'm a software developer who likes building things for the web. This is my corner of the
					internet — I write about code, projects I'm working on, and whatever I happen to be
					learning.
				</p>
			</section>

			<section>
				<div class="flex items-baseline justify-between gap-4 mb-4">
					<h2 class="text-2xl! m-0!">Recent writing</h2>
					<a class="text-sm no-underline whitespace-nowrap" href="/blog">All posts &rarr;</a>
				</div>
				<ul class="list-none m-0 p-0">
					{
						posts.map((post) => (
							<li class="border-t border-border first:border-t-0">
								<a class="group block py-4 no-underline" href={`/blog/${post.id}/`}>
									<div class="flex items-baseline justify-between gap-4 max-sm:flex-col max-sm:gap-0.5">
										<span class="font-semibold text-foreground transition-colors group-hover:text-(--blog-accent)">
											{post.data.title}
										</span>
										<span class="text-sm text-muted-foreground whitespace-nowrap">
											<FormattedDate date={post.data.pubDate} />
										</span>
									</div>
									<p class="text-sm text-muted-foreground mt-1 mb-0!">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
