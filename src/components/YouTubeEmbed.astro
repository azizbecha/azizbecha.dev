---
import { Icon } from 'astro-icon/components';

type Props = {
	videoId: string;
	/** Accessible label for the play button. */
	label: string;
};

const { videoId, label } = Astro.props;
---

<button
	type="button"
	class="yt-embed group relative aspect-video w-full cursor-pointer p-0 border-0 bg-transparent"
	data-video-id={videoId}
	aria-label={`Play: ${label}`}
>
	<img
		src={`https://i.ytimg.com/vi/${videoId}/hqdefault.jpg`}
		alt=""
		width="480"
		height="360"
		class="absolute inset-0 w-full! h-full! object-cover rounded-none! m-0!"
		loading="lazy"
	/>
	<span class="absolute inset-0 flex items-center justify-center bg-black/20 transition-colors group-hover:bg-black/40">
		<span class="flex items-center justify-center size-14 rounded-full bg-black/70 text-white transition-transform group-hover:scale-110">
			<Icon name="lucide:play" class="size-6 ml-0.5" aria-hidden="true" />
		</span>
	</span>
</button>

<script>
	// Facade: thumbnail only until clicked, then swap in the real iframe. Delegated — view-transition safe.
	document.addEventListener('click', (event) => {
		const facade = (event.target as Element).closest('.yt-embed') as HTMLElement | null;
		if (!facade || !facade.dataset.videoId) return;
		const wrapper = document.createElement('div');
		wrapper.className = 'relative aspect-video w-full';
		wrapper.innerHTML = `<iframe
			src="https://www.youtube-nocookie.com/embed/${facade.dataset.videoId}?autoplay=1"
			title="YouTube video player"
			class="absolute inset-0 size-full border-0"
			allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
			allowfullscreen></iframe>`;
		facade.replaceWith(wrapper);
	});
</script>
