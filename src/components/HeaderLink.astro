---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const normalizePath = (path: string) => (path.length > 1 ? path.replace(/\/+$/, '') : path);
const basePath = import.meta.env.BASE_URL;
const currentPath = basePath === '/' ? Astro.url.pathname : Astro.url.pathname.replace(basePath, '/');
const pathname = normalizePath(currentPath || '/');
const normalizedHref = normalizePath(String(href || '/'));
const isActive =
	normalizedHref === '/'
		? pathname === '/'
		: pathname === normalizedHref || pathname.startsWith(`${normalizedHref}/`);
---

<a
	href={href}
	class:list={[
		'text-sm no-underline transition-colors hover:text-foreground!',
		isActive ? 'text-foreground! font-medium' : 'text-muted-foreground!',
		className,
	]}
	aria-current={isActive ? 'page' : undefined}
	{...props}
>
	<slot />
</a>
