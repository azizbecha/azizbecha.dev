---
import { Image } from 'astro:assets';
import { type CollectionEntry, getEntries } from 'astro:content';
import { readingTime } from '../lib/posts';
import Byline from './Byline.astro';
import FormattedDate from './FormattedDate.astro';
import TagChip from './TagChip.astro';

type Props = {
	post: CollectionEntry<'blog'>;
	/** Set on above-the-fold cards so their hero images skip lazy loading. */
	eager?: boolean;
};

const { post, eager = false } = Astro.props;
const authors = await getEntries(post.data.authors);
---

<a
	class="group flex h-full flex-col rounded-lg border border-border overflow-hidden no-underline transition-colors hover:border-(--blog-accent)/60"
	href={`/blog/${post.id}/`}
>
	{
		post.data.heroImage && (
			<Image
				class="w-full rounded-none! m-0!"
				width={720}
				height={360}
				src={post.data.heroImage}
				alt={post.data.title}
				loading={eager ? 'eager' : 'lazy'}
			/>
		)
	}
	<div class="flex flex-col flex-1 p-4">
		<h2 class="text-lg! leading-snug! font-semibold text-foreground m-0! line-clamp-2 transition-colors group-hover:text-(--blog-accent)">
			{post.data.title}
		</h2>
		<p class="flex flex-wrap items-center gap-x-1.5 text-xs text-muted-foreground mt-1.5 mb-2!">
			<Byline authors={authors} compact />
			<span>&middot;</span>
			<FormattedDate date={post.data.pubDate} />
			<span>&middot;</span>
			<span>{readingTime(post.body)} min read</span>
		</p>
		<p class="text-sm text-muted-foreground m-0! line-clamp-2">{post.data.description}</p>
		{
			post.data.tags.length > 0 && (
				<div class="flex flex-wrap gap-1.5 mt-auto pt-3">
					{post.data.tags.map((tag) => (
						<TagChip tag={tag} />
					))}
				</div>
			)
		}
	</div>
</a>
