---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { readingTime } from '../lib/posts';
import FormattedDate from './FormattedDate.astro';

type Props = { post: CollectionEntry<'blog'> };

const { post } = Astro.props;
---

<a
	class="group flex h-full flex-col rounded-lg border border-border overflow-hidden no-underline transition-colors hover:border-(--blog-accent)/60"
	href={`/blog/${post.id}/`}
>
	{
		post.data.heroImage && (
			<Image
				class="w-full aspect-2/1 object-cover rounded-none! m-0!"
				width={720}
				height={360}
				src={post.data.heroImage}
				alt=""
			/>
		)
	}
	<div class="flex flex-col flex-1 p-4">
		<h3 class="text-lg! leading-snug! font-semibold text-foreground m-0! transition-colors group-hover:text-(--blog-accent)">
			{post.data.title}
		</h3>
		<p class="text-xs text-muted-foreground mt-1 mb-2!">
			<FormattedDate date={post.data.pubDate} /> &middot; {readingTime(post.body)} min read
		</p>
		<p class="text-sm text-muted-foreground m-0! line-clamp-2">{post.data.description}</p>
	</div>
</a>
