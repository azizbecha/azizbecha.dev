---
import { FOOTER_LINKS } from '../consts';

const year = new Date().getFullYear();
---

<footer class="border-t border-border text-muted-foreground">
	<div class="w-full max-w-5xl mx-auto px-4 py-8 font-mono text-xs">
		<p class="flex items-center gap-1 m-0!">
			<span class="text-(--blog-accent)">aziz@web</span><span>:</span><span class="text-foreground/85">~</span><span>$</span>
			<span class="text-foreground">ls ./links</span>
		</p>
		<p class="flex flex-wrap gap-x-3 gap-y-1.5 mt-1.5 mb-4!">
			{
				FOOTER_LINKS.map((link) => (
					<a
						href={link.href}
						class:list={[
							'no-underline hover:underline',
							link.dir ? 'text-(--blog-accent) font-bold' : 'text-foreground/85',
						]}
						target={link.external ? '_blank' : undefined}
						rel={link.external ? 'noopener noreferrer' : undefined}
					>
						{link.label}
					</a>
				))
			}
		</p>
		<div class="flex items-center justify-between gap-6 max-sm:flex-col max-sm:items-start max-sm:gap-3">
			<p class="flex items-center gap-1 m-0!">
				<span class="text-(--blog-accent)">aziz@web</span><span>:</span><span class="text-foreground/85">~</span><span>$</span>
				<span class="text-foreground">exit 0</span><span
					class="inline-block w-[0.6ch] h-[1.1em] bg-(--blog-accent) animate-caret-blink motion-reduce:animate-none"
					aria-hidden="true"></span>
			</p>
			<span class="text-muted-foreground/75 whitespace-nowrap">&copy; {year} &middot; no rights reserved</span>
		</div>
	</div>
</footer>
