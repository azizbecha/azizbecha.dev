---
import { Icon } from 'astro-icon/components';
import { SOCIAL_LINKS } from '../consts';

const year = new Date().getFullYear();
---

<footer class="border-t border-border text-muted-foreground">
	<div class="w-full max-w-5xl mx-auto px-4 py-10">
		<div class="flex items-start justify-between gap-8 max-sm:flex-col">
			<div>
				<p class="m-0! font-semibold text-foreground">Aziz Becha</p>
				<p class="m-0! mt-2 text-sm max-w-xs">
					My free space on the internet — thoughts, code, tips.
				</p>
			</div>
			<ul class="list-none m-0 p-0 flex items-center gap-1">
				{
					SOCIAL_LINKS.map((link) => (
						<li class="m-0">
							<a
								class="inline-flex items-center justify-center size-9 rounded-md text-muted-foreground! no-underline transition-colors hover:text-foreground! hover:bg-muted"
								href={link.href}
								aria-label={link.label}
								title={link.label}
								target={link.href.startsWith('http') ? '_blank' : undefined}
								rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
							>
								<Icon name={link.icon} class="size-4" aria-hidden="true" />
							</a>
						</li>
					))
				}
			</ul>
		</div>
		<div class="mt-8 pt-6 border-t border-border flex items-center justify-between gap-4 max-sm:flex-col max-sm:items-start">
			<p class="m-0! text-sm">&copy; {year} Aziz Becha &middot; no rights reserved</p>
			<button
				id="npx-copy"
				type="button"
				class="inline-flex items-center gap-2 rounded-md border border-border px-3 py-1.5 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground hover:border-(--blog-accent)/60 cursor-pointer"
				title="Copy to clipboard"
			>
				<span class="text-(--blog-accent)" aria-hidden="true">$</span>
				npx azizbecha
				<Icon name="lucide:copy" class="npx-copy-icon size-3" aria-hidden="true" />
				<Icon name="lucide:check" class="npx-check-icon size-3 hidden text-(--blog-accent)" aria-hidden="true" />
			</button>
		</div>
	</div>
</footer>

<script>
	// Delegated + idempotent: survives view-transition swaps.
	document.addEventListener('click', async (event) => {
		const button = (event.target as Element).closest('#npx-copy');
		if (!button) return;
		await navigator.clipboard.writeText('npx azizbecha');
		(window as any).posthog?.capture('npx_command_copied');
		const copy = button.querySelector('.npx-copy-icon');
		const check = button.querySelector('.npx-check-icon');
		copy?.classList.add('hidden');
		check?.classList.remove('hidden');
		setTimeout(() => {
			copy?.classList.remove('hidden');
			check?.classList.add('hidden');
		}, 1500);
	});
</script>
